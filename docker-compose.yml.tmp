
services:
  scraper:
    build:
      context: .
      dockerfile: Dockerfile.scraper
    ports:
      - "8000:8000"
    container_name: gunpla-scraper
    env_file: .env
    networks:
      - gunpla-network
    restart: unless-stopped
    depends_on:
      - n8n

  n8n:
    image: n8nio/n8n:latest
    container_name: gunpla-n8n
    ports:
      - "5679:5678"
    env_file: .env
    volumes:
      - n8n-data:/home/node/.n8n
    networks:
      - gunpla-network
    restart: unless-stopped

  supabase:  # FULL MAPPING (add your existing config)
    image: supabase/postgres:15.1.0.147  # Or your version
    container_name: gunpla-supabase
    ports:
      - "5432:5432"
    environment:
      POSTGRES_PASSWORD: your_password  # .env SUPABASE_DB_PASSWORD?
      PGUSER: postgres
    volumes:
      - supabase-data:/var/lib/postgresql/data
      - ./supabase-init:/docker-entrypoint-initdb.d  # pgvector + gunpla_vectors
    networks:
      - gunpla-network
    restart: unless-stopped

  doc-ingest:
    build: ./doc-ingest
    container_name: gunpla-doc-ingest
    volumes:
      - './doc-ingest:/app'
      - './doc-ingest/data:/app/data'
      - './corpus:/app/corpus:ro'
    env_file: .env
    networks:
      - gunpla-network
    restart: unless-stopped
    depends_on:
      - supabase

networks:
  gunpla-network:
    driver: bridge

volumes:
  n8n-data:
  supabase-data:
