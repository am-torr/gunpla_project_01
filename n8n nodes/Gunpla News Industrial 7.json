      "parameters": {
        "jsCode": "const prose = $input.first()?.json?.output || '';\nconst jsonMatch = prose.match(/\\[({.*?})\\]/s);\nlet newsItem;\nif (jsonMatch) {\n  try {\n    newsItem = JSON.parse('[' + jsonMatch[1] + ']');\n  } catch {\n    newsItem = {};\n  }\n} else {\n  newsItem = {\n    title: $json.title || 'MGSD Test',\n    source: $json.source || 'gunjap',\n    content: $json.content || ''\n  };\n}\nreturn [{ json: newsItem }];\n"
      },
