    {
      "parameters": {
        "jsCode": "const id = $('Supabase Archive').first().json?.id ?? Date.now();\nconst score = $json.score ?? 0;\nconst title = $json.title ?? 'Gunpla News';\nconst source = $json.source ?? '';\nconst content = $json.content ?? '';\nconst tier = $json.tier ?? 'digest';\n// postCopy fallback to content if empty\nconst postCopy = ($json.postCopy && $json.postCopy.trim() !== '')\n  ? $json.postCopy\n  : `🚨 ${title} - ${content}`;\nconst base = 'http://localhost:5679/webhook/gunpla-approve';\n\nreturn [{json: {\n  subject: `🚨 [TIER${score >= 9 ? '1' : '2'}] Approve: ${title.slice(0,50)}`,\n  body: postCopy + '\\n\\n' +\n        'Score: ' + score + '/10 | Source: ' + source + ' | Tier: ' + tier + '\\n\\n' +\n        '✅ APPROVE: ' + base + '?action=approve&id=' + id + '\\n' +\n        '❌ REJECT:  ' + base + '?action=reject&id=' + id,\n  id, title, score, postCopy\n}}];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1504,
        -1712
      ],
      "id": "baee0b15-d27f-4908-ba5e-73aa3314986b",
      "name": "Approval filter"
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst prose = input.output || '';\n\n// Aggressive parse: numbers, booleans, lists from prose\nconst scoreMatch = prose.match(/score[ \\t:]*(\\d+)/i);\nconst approveMatch = prose.match(/approve[ \\t:]*([true|false])/i);\nconst tierMatch = prose.match(/tier[ \\t:]*[\"'`]?([^\",`\\n]+)/i);\nconst tagsMatch = prose.match(/tags[ \\t:]*\\[(.*?)\\]/i);\n\n// JSON fallback first\nlet parsed = {};\ntry {\n  parsed = JSON.parse(prose);\n} catch {\n  // Prose extract\n  parsed.score = parseInt(scoreMatch?.[1] || 0);\n  parsed.approve = approveMatch?.[1]?.toLowerCase() === 'true';\n  parsed.tier = tierMatch?.[1]?.trim() || 'digest';\n  \n  if (tagsMatch?.[1]) {\n    parsed.tags = tagsMatch[1].split(',').map(t => t.trim().replace(/[\"'\\[\\]]/g, ''));\n  }\n}\n\n// Merge input + parsed\nreturn [{\n  json: {\n    title: input.title || parsed.title || 'Unknown',\n    source: input.source || parsed.source || 'unknown',\n    content: input.content || parsed.content || '',\n    ...parsed,\n    postCopy: parsed.postCopy || ''\n  }\n}];\n"
      },
