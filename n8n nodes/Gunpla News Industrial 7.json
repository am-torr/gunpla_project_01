    {
      "parameters": {
        "jsCode": "const item = $json;\n\n// Ngeekhong Golden Traits applied:\n// 1. Raw facts first (grade, price, release)\n// 2. PHP equivalent (PH localization gap)\n// 3. Beginner context line if applicable\n// 4. Primary source URL (credibility)\n// 5. FOMO copy only for Tier 1 (P-Bandai/PGU/MGSD)\n// 6. Neutral tone — no elitism, all grades valid\n// 7. Affiliate link appended\n\nconst score   = item.score  ?? 0;\nconst title   = item.title  ?? 'Gunpla News';\nconst source  = item.source ?? 'unknown';\nconst content = item.content ?? '';\nconst tier    = item.tier   ?? 'digest';\nconst tags    = item.tags   ?? [];\n\n// PHP conversion (approx ¥1 = ₱0.40, adjust in Supabase or cron)\nconst phpRate = 0.40;\nconst yenMatch = content.match(/[¥￥](\\d[\\d,]+)/);\nconst yenPrice = yenMatch ? parseInt(yenMatch[1].replace(/,/g, '')) : null;\nconst phpPrice = yenPrice ? Math.round(yenPrice * phpRate).toLocaleString() : null;\n\n// Grade → beginner context map (ngeekhong equal-grade philosophy)\nconst gradeContext = {\n  'HG':   '🟢 High Grade — Best starter kit. Build time: 1-2 hrs.',\n  'RG':   '🔵 Real Grade — HG detail at MG price. Panel lines heaven.',\n  'MG':   '🟡 Master Grade — Inner frame, serious detail. 4-8 hrs.',\n  'PG':   '🔴 Perfect Grade — Full mechanical detail. 20+ hrs.',\n  'MGSD': '⭐ MGSD — Super Deformed with MG-level engineering. Unique.',\n  'MGEX': '🔴 MG Extreme — LED, chrome, top-tier. Grail kit.',\n};\nconst gradeKey = Object.keys(gradeContext).find(k =>\n  title.toUpperCase().includes(k) || (tags.join(' ').toUpperCase().includes(k))\n);\nconst beginnerLine = gradeContext[gradeKey] ?? '';\n\n// FOMO trigger (Tier 1 only — ngeekhong never overhyped Tier 3)\nconst isTier1 = score >= 9 || tier === 'urgent';\nconst fomoLine = isTier1\n  ? `\\n🚨 P-Bandai / Limited window — order fast or pay scalper price.`\n  : '';\n\n// Affiliate link (HLJ default, swap for Shopee/GTO per source)\nconst affiliateBase = 'https://hlj.com/?ref=mechahub';\nconst affiliateLink = `\\n🛒 Check availability: ${affiliateBase}`;\n\n// Source credibility line (ngeekhong always cited primary)\nconst sourceMap = {\n  'gunjap':      '📰 Source: GUNJAP.net (JP primary)',\n  'gundam.info': '📰 Source: Gundam.info (Official)',\n  'reddit':      '📰 Source: r/Gunpla community',\n  'bandai':      '📰 Source: Bandai Hobby Site (Official)',\n  'hobbyplanet': '📰 Source: Hobby Planet PH',\n};\nconst sourceLine = sourceMap[source.toLowerCase()] ?? `📰 Source: ${source}`;\n\n// Build the post\nconst phpLine = phpPrice\n  ? `💰 Est. PHP: ₱${phpPrice} (¥${yenPrice?.toLocaleString()} at today's rate)`\n  : '';\n\nconst postCopy =\n`${isTier1 ? '🔥' : '📢'} ${title}\n\n${content}\n${phpLine ? '\\n' + phpLine : ''}\n${beginnerLine ? '\\n' + beginnerLine : ''}\n${fomoLine}\n${affiliateLink}\n\n${sourceLine}\n#Gunpla #MechaHub ${tags.map(t => '#' + t.replace(/\\s+/g, '')).join(' ')}`.trim();\n\nreturn [{\n  json: {\n    ...item,\n    postCopy,\n    phpPrice,\n    gradeKey,\n    isTier1\n  }\n}];\n"
      },
