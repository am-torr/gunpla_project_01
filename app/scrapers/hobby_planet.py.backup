import requests
from bs4 import BeautifulSoup
import re
import time
import logging
from datetime import datetime
from typing import List, Dict, Optional
from .base_scraper import BaseScraper  # â† Relative import
from ..database import db  # â† Relative import

logger = logging.getLogger(__name__)


class HobbyPlanetScraper(BaseScraper):
    """Hobby Planet Collectibles Gunpla Scraper"""

    def __init__(self):
        super().__init__()
        self.store_name = "Hobby Planet"
        self.base_url = "https://hobbyplanet.info"
        self.gunpla_url = f"{self.base_url}/product-category/gunpla/"

    def extract_grade_from_text(self, text: str) -> Optional[str]:
        """Extract grade from product name"""
        grade_patterns = {
            "MGEX": r"\bMGEX\b",
            "MG": r"\bMG\b",
            "RG": r"\bRG\b",
            "PG": r"\bPG\b",
            "HG": r"\b(?:HG|HGUC|HGCE|HGBF|HGAW)\b",
            "SD": r"\bSD\b",
            "RE/100": r"\bRE/100\b",
        }

        for grade, pattern in grade_patterns.items():
            if re.search(pattern, text, re.IGNORECASE):
                return grade
        return None

    def extract_scale(self, text: str, grade: Optional[str]) -> str:
        """Extract scale from text or infer from grade"""
        scale_match = re.search(r"1/(\d+)", text)
        if scale_match:
            return f"1/{scale_match.group(1)}"

        scale_map = {
            "HG": "1/144",
            "RG": "1/144",
            "MG": "1/100",
            "MGEX": "1/100",
            "RE/100": "1/100",
            "PG": "1/60",
        }
        return scale_map.get(grade, "N/A")

    def detect_special_edition(self, name: str) -> str:
        """Detect special edition type"""
        name_upper = name.upper()
        if "PREMIUM BANDAI" in name_upper or "P-BANDAI" in name_upper:
            return "P-Bandai"
        if "GUNDAM BASE" in name_upper:
            return "Gundam Base Limited"
        if "CLEAR" in name_upper or "MECHANICAL CLEAR" in name_upper:
            return "Clear Version"
        if "SPECIAL COATING" in name_upper:
            return "Special Coating"
        return "Standard"

    def parse_product(self, product_element) -> Optional[Dict]:
        """Parse individual product card"""
        try:
            # 1. Product URL
            product_link = product_element.find("a", href=re.compile(r"/product/"))
            if not product_link:
                return None
            product_url = product_link.get("href", "")

            # 2. Product Name (multiple fallback methods)
            product_name = None

            # Try title attribute first
            product_name = product_link.get("title")

            # Try h2/h3 product title
            if not product_name:
                title_elem = product_element.find(["h2", "h3"], class_=re.compile(r"title"))
                if title_elem:
                    product_name = title_elem.get_text(strip=True)

            # Try text in product-description (filter out categories)
            if not product_name:
                desc_div = product_element.find("div", class_="product-description")
                if desc_div:
                    for text_node in desc_div.find_all(string=True, recursive=True):
                        text = text_node.strip()
                        # Filter out short texts and common words
                        if (
                            len(text) > 15
                            and "Add to cart" not in text
                            and text
                            not in ["High Grade", "Master Grade", "Real Grade", "SD", "On Stock"]
                        ):
                            product_name = text
                            break

            # Fallback: extract from URL
            if not product_name:
                slug = product_url.split("/product/")[-1].strip("/")
                product_name = " ".join(word.capitalize() for word in slug.split("-"))

            # 3. Grade
            grade = None
            categories = product_element.find_all("a", class_="shopical-categories")
            grade_map = {
                "High Grade": "HG",
                "Master Grade": "MG",
                "Real Grade": "RG",
                "Perfect Grade": "PG",
                "SD": "SD",
                "MGEX": "MGEX",
            }
            for cat in categories:
                cat_text = cat.get_text(strip=True)
                if cat_text in grade_map:
                    grade = grade_map[cat_text]
                    break

            if not grade:
                grade = self.extract_grade_from_text(product_name)

            # 4. Scale
            scale = self.extract_scale(product_name, grade)

            # 5. Price
            price = None
            price_element = product_element.find("bdi")
            if price_element:
                price_text = price_element.get_text(strip=True)
                price_clean = re.sub(r'[^\d.]', '', price_text)
                try:
                    price = float(price_clean)
                except ValueError:
                    pass

            # 6. Stock Status
            stock_status = "Unknown"
            classes = product_element.get("class", [])
            if "instock" in classes:
                stock_status = "In Stock"
            elif "outofstock" in classes:
                stock_status = "Out of Stock"

            for cat in categories:
                if "On Stock" in cat.get_text():
                    stock_status = "In Stock"
                    break

            # 7. Special Edition
            special_edition = self.detect_special_edition(product_name)

            return {
                "product": {
                    "product_name": product_name,
                    "grade": grade,
                    "scale": scale,
                    "special_edition": special_edition,
                    "bandai_sku": None,  # Extract later if available
                },
                "price": {
                    "price": price,
                    "currency": "PHP",
                    "stock_status": stock_status,
                    "product_url": product_url,
                },
            }

        except Exception as e:
            logger.error(f"Error parsing product: {e}")
            return None

    async def scrape(self, limit: Optional[int] = None) -> List[Dict]:
        """Main scrape method"""
        logger.info(f"ðŸ”„ Starting scrape: {self.store_name}")
        products = []

        try:
            soup = self.fetch_page(self.gunpla_url)
            product_containers = soup.find_all("li", class_=re.compile(r"product"))

            if limit:
                product_containers = product_containers[:limit]

            logger.info(f"Found {len(product_containers)} products")

            for idx, product_elem in enumerate(product_containers, 1):
                product_data = self.parse_product(product_elem)

                if product_data:
                    # Save to database
                    # product_id = self.save_product  # TODO: Uncomment when database is ready(product_data['product'])
                    # self.save_price  # TODO: Uncomment when database is ready(product_id, product_data['price'])
                    products.append(product_data)

                    logger.info(f"[{idx}] âœ“ {product_data['product']['product_name'][:50]}")

                time.sleep(self.delay)

            logger.info(f"âœ… Scraped {len(products)} products from {self.store_name}")
            return products

        except Exception as e:
            logger.error(f"âŒ Scrape failed for {self.store_name}: {e}")
            raise
